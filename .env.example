# Copy to .env and adjust before: docker compose up -d

POSTGRES_USER=tiktok_farm
POSTGRES_PASSWORD=tiktok_farm_secret
POSTGRES_DB=tiktok_farm
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Optional: overrides settings.yaml when set
# DATABASE_URL=postgresql://tiktok_farm:tiktok_farm_secret@localhost:5433/tiktok_farm

REDIS_PORT=6379

# Optional: public TikTok profile lookup (pip install TikTokApi)
# Copy msToken from DevTools → Application → Cookies on https://www.tiktok.com
TIKTOK_MS_TOKEN=
TIKTOK_BROWSER=chromium
